# Shared
APP_ENV=dev
APP_NAME=finance-trading-app

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:4200

# Auth (replace before production)
JWT_SECRET=replace-me
JWT_EXPIRES_MINUTES=60

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_app
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=trading_pass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (optional object storage for Parquet snapshots/artifacts)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=market-data

# IBKR / Trading
IBKR_HOST=127.0.0.1
IBKR_PORT=5000
IBKR_CLIENT_ID=1001
TRADING_MODE=paper
