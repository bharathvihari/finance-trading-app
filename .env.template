# ============================================================================
# Finance Trading App - Environment Configuration Template
# Copy this to .env and fill in actual values for your environment
# ============================================================================

# --- API Server ---
APP_NAME=finance-trading-app-api
API_HOST=0.0.0.0
API_PORT=8000

# --- PostgreSQL (Hot Tier - Recent Data) ---
POSTGRES_ENABLED=true
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=trading_app
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_SCHEMA=market_data
POSTGRES_BARS_TABLE=daily_bars

# --- Redis (Cache & Message Broker) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Parquet/DuckDB (Cold Tier - Historical Data) ---
PARQUET_ROOT=data/parquet/price-data
DUCKDB_PATH=data/duckdb/market_data.duckdb

# --- Hot/Cold Tier Cutoff ---
# Must match the value used in the backfill job for correct tier boundary alignment
HOT_WINDOW_MONTHS=6

# --- JWT Authentication ---
JWT_SECRET_KEY=change-me-in-production-with-strong-random-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# --- Caching ---
CACHE_ENABLED=true

# --- MinIO (S3-compatible Object Storage) ---
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=change-me-in-production
MINIO_ENDPOINT=minio:9000

# --- Nginx (Reverse Proxy) ---
NGINX_PORT=80
NGINX_TLS_PORT=443
NGINX_TLS_CERT=/etc/nginx/certs/cert.pem
NGINX_TLS_KEY=/etc/nginx/certs/key.pem

# --- Logging & Debugging ---
LOG_LEVEL=INFO
DEBUG=false
